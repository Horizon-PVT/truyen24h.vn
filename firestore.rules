rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function safeUserCreateFields() {
      return [
        'uid',
        'displayName',
        'email',
        'photoURL',
        'bio',
        'preferences',
        'readingSettings',
        'theme',
        'createdAt',
        'updatedAt'
      ];
    }

    function safeUserUpdateFields() {
      return [
        'uid',
        'displayName',
        'email',
        'photoURL',
        'bio',
        'preferences',
        'readingSettings',
        'theme',
        'createdAt',
        'updatedAt',
        'lastActiveAt'
      ];
    }

    function safeBookshelfFields() {
      return [
        'novelId',
        'lastChapterId',
        'lastChapterNumber',
        'progress',
        'isFollowing',
        'isReadLater',
        'createdAt',
        'updatedAt'
      ];
    }

    function isNovelAuthor(novelId) {
      return signedIn()
        && get(/databases/$(database)/documents/novels/$(novelId)).data.authorId == request.auth.uid;
    }

    // Users: public profile reads are preserved, but money/admin/accounting
    // fields are server-only and omitted from all client-writable allowlists.
    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly(safeUserCreateFields())
        && request.resource.data.uid == userId;

      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(safeUserUpdateFields())
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId);

      allow delete: if false;

      // Non-money reading progress / bookshelf data. Paid unlock state must stay
      // on the server-controlled user document, not in this client-writable path.
      match /bookshelf/{novelId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasOnly(safeBookshelfFields())
          && (!('novelId' in request.resource.data) || request.resource.data.novelId == novelId);
        allow delete: if isOwner(userId);
      }

      // Reward/accounting records are written by server routes using Admin SDK.
      match /checkins/{checkinId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /missions/{missionId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /profile/{profileDocId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /{document=**} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // Public fiction content remains readable. Authors can still manage their
    // own novels/chapters from the client; admin/server publishing bypasses
    // rules through Firebase Admin SDK.
    match /novels/{novelId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId;
      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid;

      match /chapters/{chapterId} {
        allow read: if true;
        allow create, update, delete: if isNovelAuthor(novelId);

        match /inline_comments/{commentId} {
          allow read: if true;
          allow create: if signedIn()
            && request.resource.data.userId == request.auth.uid;
          allow update, delete: if signedIn()
            && resource.data.userId == request.auth.uid;
        }
      }
    }

    // Public blog reads are preserved. Writes must go through admin/server code.
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if false;
    }

    // Payment/order/accounting collections are server-only for writes. Users may
    // read only records tied to their verified uid where the owner field exists.
    match /orders/{orderId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /transactions/{txId} {
      allow read: if signedIn()
        && (
          resource.data.uid == request.auth.uid
          || resource.data.buyerId == request.auth.uid
          || resource.data.donorId == request.auth.uid
          || resource.data.authorId == request.auth.uid
        );
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /payos_orders/{orderId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /payment_logs/{logId} {
      allow read, write: if false;
    }

    match /revenue_events/{eventId} {
      allow read, write: if false;
    }

    match /platform_revenue/{docId} {
      allow read, write: if false;
    }

    match /withdraw_requests/{requestId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Admin, ops, and configuration state are not client-writable.
    match /admin/{document=**} {
      allow read, write: if false;
    }

    match /config/{document=**} {
      allow read, write: if false;
    }

    match /ops_daily_runs/{runId} {
      allow read, write: if false;
    }

    // Community chat remains non-money user content.
    match /channels/{channelId}/messages/{messageId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    // Fail closed for every other collection, especially unknown sensitive
    // payment, admin, automation, or revenue paths.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Users Collection
    match /users/{userId} {
      // Cho phép đọc thông tin user công khai
      allow read: if true;
      
      // Cho phép user tự sửa thông tin CỦA MÌNH
      // Coins chỉ được GIẢM (trả xu khi unlock/donate), KHÔNG được tự cộng
      allow write: if request.auth != null && request.auth.uid == userId 
                   && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'unlockedChapters', 'donateQR', 'lastCheckIn', 'coins', 'contributionScore', 'badges', 'checkInStreak', 'longestStreak']))
                   && (
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['coins'])
                     || request.resource.data.coins <= resource.data.coins
                   );

      // Reading progress — chỉ user ấy đọc/ghi của chính mình.
      // Subcollections KHÔNG kế thừa rules cha, phải khai báo riêng nếu không
      // sẽ default-deny → onSnapshot client trả empty + button không update label.
      match /reading_progress/{novelId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Bookshelf — same scope: only self.
      match /bookshelf/{bookshelfId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Check-in audit log — chỉ self đọc.
      match /checkins/{date} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // chỉ Admin SDK ghi (via /api/checkin/claim)
      }

      // Daily missions progress — chỉ self đọc; ghi qua Admin SDK.
      match /daily_missions/{date}/progress/{missionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // 2. Cho phép CỘNG xu cho tác giả khi mua chương/donate
    // Chỉ cho phép: user đã đăng nhập + chỉ sửa field coins + coins tăng lên (increment)
    // + KHÔNG được tự cộng cho CHÍNH MÌNH (ngăn exploit)
    match /users/{authorId} {
       allow update: if request.auth != null 
                     && request.auth.uid != authorId
                     && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins'])
                     && request.resource.data.coins > resource.data.coins;
    }

    // 3. Truyện (Novels)
    match /novels/{novelId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
      
      // Novel-level reviews + ratings (used by CommentSection)
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }

      // Chương truyện (Chapters)
      match /chapters/{chapterId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/novels/$(novelId)).data.authorId == request.auth.uid;

        // Inline Comments (paragraph-level)
        match /inline_comments/{commentId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
        }

        // Chapter-level comments (flat list shown under the reader)
        match /comments/{commentId} {
          allow read: if true;
          allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
          allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
        }
      }
    }

    // 4. Lịch sử Giao Dịch
    match /transactions/{txId} {
      allow read: if request.auth != null && (resource.data.buyerId == request.auth.uid || resource.data.authorId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if false;
    }

    // 5. Lệnh rút tiền
    match /withdraw_requests/{reqId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'PENDING';
      allow update, delete: if false;
    }

    // 6. Blog posts — đọc công khai. Ghi/sửa/xoá chỉ qua Admin SDK
    // (Admin SDK bypass rules) hoặc người dùng đã login (kiểm soát thêm
    // bằng email whitelist phía server route).
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if false;
    }

    // 7. Newsletter subscribers — public form đăng ký email. Bất kỳ ai
    // cũng tạo được; chỉ Admin SDK đọc/sửa (qua route /api/admin/*).
    match /newsletter_subscribers/{subId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

  }
}

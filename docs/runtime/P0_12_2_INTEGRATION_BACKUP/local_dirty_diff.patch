+async function fetchNovel(slug: string): Promise<Novel | null> {
+  try {
+    const snap = await adminDb().collection('novels').doc(slug).get();
+    if (snap.exists) return asNovel(serializeFirestore({ id: snap.id, ...snap.data() }));
+  } catch (error) {
+    console.warn('Admin SDK novel read failed; falling back to client SDK.', error);
+  }
+
+  try {
+    const snap = await getDoc(doc(clientDb, 'novels', slug));
+    if (snap.exists()) return asNovel(serializeFirestore({ id: snap.id, ...snap.data() }));
+  } catch (error) {
+    console.warn('Client SDK novel read fallback failed.', error);
+  }
+
+  try {
+    const restDoc = await fetchFirestoreRestDocument(`novels/${slug}`);
+    if (restDoc) return asNovel(serializeFirestore(restDoc));
+  } catch (error) {
+    console.warn('REST novel read fallback failed.', error);
+  }
+
+  return NOVELS.find((novel) => novel.id === slug) || null;
+}
 
